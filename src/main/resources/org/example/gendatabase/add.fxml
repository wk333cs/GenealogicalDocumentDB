<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="add" prefHeight="400.0" prefWidth="600.0" style="-fx-background-color: #4ceefc;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.gendatabase.AddController">
    <children>
        <VBox alignment="TOP_CENTER" layoutX="250.0" layoutY="75.0" prefHeight="200.0" prefWidth="100.0" style="-fx-background-color: white;" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="10.0">
            <children>
                <HBox prefHeight="100.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
                    <children>
                        <VBox prefHeight="200.0" prefWidth="800.0" HBox.hgrow="ALWAYS">
                            <children>
                                <HBox alignment="CENTER_LEFT" prefHeight="50.0" prefWidth="200.0" spacing="15.0" VBox.vgrow="ALWAYS">
                                    <children>
                                        <Label alignment="TOP_RIGHT" text="Name" HBox.hgrow="NEVER">
                                            <HBox.margin>
                                                <Insets left="15.0" />
                                            </HBox.margin>
                                        </Label>
                                        <TextField id="nameField" fx:id="nameField" HBox.hgrow="ALWAYS">
                                            <HBox.margin>
                                                <Insets right="20.0" />
                                            </HBox.margin>
                                        </TextField>
                                    </children>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" prefHeight="50.0" prefWidth="200.0" spacing="5.0" VBox.vgrow="ALWAYS">
                                    <children>
                                        <Label text="Surname" HBox.hgrow="NEVER">
                                            <HBox.margin>
                                                <Insets left="10.0" />
                                            </HBox.margin>
                                        </Label>
                                        <TextField id="surnameField" fx:id="surnameField" HBox.hgrow="ALWAYS">
                                            <HBox.margin>
                                                <Insets right="20.0" />
                                            </HBox.margin>
                                        </TextField>
                                    </children>
                                </HBox>
                                <HBox alignment="CENTER" layoutX="10.0" layoutY="60.0" prefHeight="50.0" prefWidth="200.0" spacing="10.0" VBox.vgrow="ALWAYS">
                                    <children>
                                        <Label text="Type" />
                                        <ChoiceBox id="typeBox" fx:id="typeBox" prefWidth="90.0" />
                                        <Region prefHeight="200.0" prefWidth="100.0" HBox.hgrow="NEVER" />
                                        <Label text="Year" />
                                        <TextField id="yearField" fx:id="yearField" prefWidth="100.0" />
                                        <Region prefHeight="200.0" prefWidth="100.0" HBox.hgrow="NEVER" />
                                        <Label text="Branch" />
                                        <ChoiceBox id="branchBox" fx:id="branchBox" prefWidth="60.0" HBox.hgrow="NEVER">
                                            <opaqueInsets>
                                                <Insets />
                                            </opaqueInsets>
                                            <HBox.margin>
                                                <Insets />
                                            </HBox.margin>
                                        </ChoiceBox>
                                    </children>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" layoutX="10.0" layoutY="111.0" prefHeight="50.0" prefWidth="200.0" spacing="15.0" VBox.vgrow="ALWAYS">
                                    <children>
                                        <Label text="Parish">
                                            <padding>
                                                <Insets left="15.0" />
                                            </padding>
                                        </Label>
                                        <TextField id="parishField" fx:id="parishField" HBox.hgrow="ALWAYS">
                                            <HBox.margin>
                                                <Insets right="20.0" />
                                            </HBox.margin>
                                        </TextField>
                                    </children>
                                </HBox>
                                <HBox layoutX="10.0" layoutY="161.0" prefHeight="50.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
                                    <children>
                                        <HBox alignment="CENTER_LEFT" prefHeight="100.0" prefWidth="200.0" spacing="15.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="City">
                                                    <HBox.margin>
                                                        <Insets left="15.0" />
                                                    </HBox.margin>
                                                </Label>
                                                <TextField id="cityField" fx:id="cityField" HBox.hgrow="ALWAYS">
                                                    <HBox.margin>
                                                        <Insets right="15.0" />
                                                    </HBox.margin>
                                                </TextField>
                                            </children>
                                        </HBox>
                                        <HBox alignment="CENTER_LEFT" prefHeight="100.0" prefWidth="200.0" spacing="15.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Village">
                                                    <padding>
                                                        <Insets left="10.0" />
                                                    </padding>
                                                </Label>
                                                <TextField id="villageField" fx:id="villageField" HBox.hgrow="ALWAYS">
                                                    <HBox.margin>
                                                        <Insets right="20.0" />
                                                    </HBox.margin>
                                                </TextField>
                                            </children>
                                        </HBox>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                        <HBox alignment="TOP_RIGHT" prefHeight="100.0" prefWidth="75.0" spacing="50.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Button id="saveButton" fx:id="saveButton" mnemonicParsing="false" onAction="#onSaveButtonClicked" prefHeight="50.0" prefWidth="90.0" text="Save" HBox.hgrow="NEVER">
                                    <HBox.margin>
                                        <Insets top="15.0" />
                                    </HBox.margin>
                                </Button>
                                <Button mnemonicParsing="false" prefHeight="50.0" prefWidth="50.0" text="Pin" HBox.hgrow="NEVER">
                                    <HBox.margin>
                                        <Insets right="20.0" top="15.0" />
                                    </HBox.margin>
                                </Button>
                            </children>
                            <HBox.margin>
                                <Insets right="5.0" />
                            </HBox.margin>
                        </HBox>
                    </children>
                </HBox>
                <Label maxWidth="1.7976931348623157E308" text="Aditional Information" VBox.vgrow="NEVER">
                    <font>
                        <Font size="13.0" />
                    </font>
                    <VBox.margin>
                        <Insets left="10.0" />
                    </VBox.margin>
                </Label>
                <TextArea id="infoArea" fx:id="infoArea" prefHeight="25.0" prefWidth="570.0" VBox.vgrow="ALWAYS">
                    <VBox.margin>
                        <Insets bottom="10.0" left="5.0" right="5.0" />
                    </VBox.margin>
                </TextArea>
            </children>
        </VBox>
    </children>
</AnchorPane>
